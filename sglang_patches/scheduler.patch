+    def _graphpool_init(self):
+        """Initialize GraphPool Arbiter if configured."""
+        import os
+        archive_dir = os.environ.get("GRAPHPOOL_ARCHIVE")
+        if not archive_dir or not os.path.isdir(archive_dir):
+            self._gp_arbiter = None
+            return
+        try:
+            import sys
+            gp_dir = "/home/zhujianian/graphpool"
+            if gp_dir not in sys.path:
+                sys.path.insert(0, gp_dir)
+            from arbiter import GraphPoolArbiter
+            from executor import GraphPoolExecutor
+            self._gp_arbiter = GraphPoolArbiter(archive_dir)
+            self._gp_executor = GraphPoolExecutor(archive_dir)
+            logger.info(
+                f"[GraphPool] Arbiter initialized: archive={archive_dir}, "
+                f"available_bs={len(self._gp_arbiter.get_available_archive_bs())}"
+            )
+        except Exception as e:
+            logger.warning(f"[GraphPool] Arbiter init failed: {e}")
+            self._gp_arbiter = None
+
+    def _graphpool_tick(self, batch):
+        """Feed scheduler signals to GraphPool Arbiter after each batch."""
+        if not hasattr(self, '_gp_arbiter'):
+            self._graphpool_init()
+        if self._gp_arbiter is None:
+            return
+
+        try:
+            import time as _time
+            from arbiter import DemandSignal
+
+            decode_bs = batch.batch_size() if batch and not batch.forward_mode.is_extend() else 0
+            kv_avail = self.req_to_token_pool.available_size() / max(1, self.req_to_token_pool.size)
+
+            signal = DemandSignal(
+                timestamp=_time.monotonic(),
+                decode_bs=decode_bs,
+                waiting_queue_len=len(self.waiting_queue),
+                running_count=len(self.running_batch.reqs) if self.running_batch else 0,
+                kv_available_ratio=kv_avail,
+                graph_hit=getattr(batch, '_graphpool_hit', True),
+                padded_bs=decode_bs,
+            )
+
+            actions = self._gp_arbiter.on_iteration(signal)
+
+            if actions and hasattr(self, 'tp_worker') and self.tp_worker:
+                model_runner = self.tp_worker.model_runner
+                if hasattr(model_runner, 'graph_runner') and model_runner.graph_runner:
+                    for action in actions:
+                        self._gp_executor.execute_action(action, model_runner.graph_runner)
+
+        except Exception as e:
+            if self._gp_arbiter.state.total_iters < 5:
+                logger.warning(f"[GraphPool] Arbiter tick error: {e}")
+
