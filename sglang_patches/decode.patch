+    def _dualstate_fork_if_needed(self, decode_req: DecodeRequest):
+        """FSM transition: RECEIVED -> FORK (or RECEIVED -> ACTIVE)."""
+        from sglang.srt.disaggregation.dualstate_coherence import (
+            DualStateCoherenceManager,
+        )
+        from sglang.srt.mem_cache.checkpoint_availability_map import (
+            compute_prefix_hash,
+        )
+
+        req = decode_req.req
+        origin_ids = getattr(req, "origin_input_ids", None)
+        if origin_ids is None:
+            return
+
+        if getattr(req, "dualstate_mamba_from_cache", False):
+            return
+
+        prefix_hash = compute_prefix_hash(origin_ids)
+
+        if not self._dualstate_scheduler.should_cache(
+            prefix_hash=prefix_hash,
+            prefix_len=len(origin_ids),
+            cam=self._dualstate_cam,
+        ):
+            return
+
+        # In disaggregated decode, mamba index is in the pool mapping, not req.mamba_pool_idx
+        req_pool_idx = getattr(req, "req_pool_idx", None)
+        if req_pool_idx is None:
+            return
+
+        pool = self.scheduler.req_to_token_pool
+        if not hasattr(pool, "req_index_to_mamba_index_mapping"):
+            return
+
+        mamba_slot = pool.req_index_to_mamba_index_mapping[req_pool_idx]
+        if mamba_slot is None:
+            return
+
+        if isinstance(mamba_slot, torch.Tensor):
+            mamba_slot = mamba_slot.reshape(-1)
+        else:
+            mamba_slot = torch.tensor([int(mamba_slot)], dtype=torch.int64)
+
+        # Ensure on same device as mamba pool
+        pool_device = self._dualstate_cam._mamba_pool.device
+        mamba_slot = mamba_slot.to(pool_device)
+
+        # Ensure P→D transfer is fully written before we fork
+        torch.cuda.synchronize()
+
+        cached_slot = self._dualstate_cam.fork_and_cache(
+            prefix_hash=prefix_hash,
+            prefix_len=len(origin_ids),
+            src_mamba_indices=mamba_slot,
+        )
+
+        if cached_slot is not None:
+            logger.info(
+                f"DualState FSM: forked mamba state for prefix {prefix_hash[:8]}... "
+                f"(src_slot={mamba_slot.tolist()} -> cached_slot={cached_slot.tolist()})"
+            )
+            coherence_mgr = DualStateCoherenceManager.get_instance()
+            coherence_mgr.d_report_cache_status(prefix_hash, len(origin_ids), "C")
+
